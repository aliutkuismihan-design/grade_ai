# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# --- Grande AI backend (your private server) ---------------------------
# Production:  https://grande-ai.yourdomain.com/v1
# Local/dev:   http://YOUR_SERVER_IP:8080/v1
GRANDE_AI_BASE_URL=https://grande-ai.yourdomain.com/v1

# Bearer token sent as: Authorization: Bearer <GRANDE_AI_API_KEY>
GRANDE_AI_API_KEY=ga-xxxxxxxxxxxxxxxxxxxxxxxx

# Set to true to bypass the network and return canned grading results while the
# backend is not yet deployed.
USE_MOCK_GRADING=true

# --- Google AdMob -----------------------------------------------------------
# Leave these blank to use Google's official TEST ad units during development.
# Create an AdMob account with ali.utku.ismihan@gmail.com, register the app, and
# paste the real IDs here before release. See README → Monetization.
ADMOB_APP_ID=
ADMOB_BANNER_ID=
ADMOB_INTERSTITIAL_ID=
ADMOB_REWARDED_ID=
