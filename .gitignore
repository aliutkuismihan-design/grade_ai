#       Firebase identifiers. If you prefer to keep even those out of the repo,
#       uncomment the next line:
# lib/firebase_options.dart

# OS
.DS_Store
Thumbs.db

# Codegen output is regenerated via build_runner; keep it out of VCS
*.g.dart
*.freezed.dart

# pubspec.lock IS committed for apps (kept, not ignored)
